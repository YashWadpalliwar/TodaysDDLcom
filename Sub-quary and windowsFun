-- 1) Get the name of each employee and their salary 
	-- along with the highest salary in the company using subquery:

SELECT name, salary,
    (SELECT MAX(salary) FROM EmployeesData1) AS highest_salary
FROM 
    EmployeesData1;


-- 2) Find all employees' names who have a salary 
	-- greater than the average salary of all employees using subquery:

SELECT name,salary FROM EmployeesData1
WHERE salary > (SELECT AVG(salary) FROM EmployeesData1);

select avg(salary) from EmployeesData1;

